# ============================================================
# PolyBot v1.0 — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Telegram Owner User ID (your personal Telegram ID)
TELEGRAM_OWNER_ID=123456789

# Polymarket CLOB — Private Key (Polygon wallet)
# WARNING: This wallet will place REAL trades with REAL money
# Use a dedicated wallet with ONLY the amount you're willing to risk
POLYMARKET_PRIVATE_KEY=0x_your_private_key_here

# Polymarket — Proxy Wallet (optional, for gasless approvals)
POLYMARKET_PROXY_ADDRESS=0x_your_proxy_wallet_address

# Fernet Encryption Key (generate once: python -c "from cryptography.fernet import Fernent; print(Fernet.generate_key().decode())")
FERNET_KEY=your_fernet_key_here

# API Endpoints
POLYMARKET_CLOB_URL=https://clob.polymarket.com
POLYMARKET_GAMMA_URL=https://gamma-api.polymarket.com
POLYMARKET_DATA_URL=https://data-api.polymarket.com

# The Graph — Polymarket Subgraph (for deep wallet tracking)
SUBGRAPH_URL=https://api.studio.thegraph.com/query/51510/polymarket-polygon/version/latest

# Rate Limiting
API_RATE_LIMIT_RPS=10

# Database
DATABASE_PATH=data/polybot.db
